rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if user is admin
    // Assuming we either set custom claims or trust the client role for now 
    // In a production app, custom claims request.auth.token.admin == true should be used.
    function isAdmin() {
      return request.auth.token.email == 'magnus.ohlund@outlook.com' || 
             request.auth.token.email == 'magnus.ohlund74@gmail.com';
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth.uid == userId 
                   || isAdmin()
                   || (resource != null && request.auth.token.email != null && (request.auth.token.email == resource.data.email || request.auth.token.email in resource.data.emails));
    }

    match /trips/{tripId} {
      // Trips use unguessable UUIDs. Any authenticated user with the link can read/update.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated(); // Could be locked down further
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
