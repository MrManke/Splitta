# Firebase Konfiguration
# Skapa ett projekt på https://console.firebase.google.com/
# Aktivera Authentication (Google + Email) och Firestore Database.
# Klistra in dina nycklar nedan (döp om filen till .env)

VITE_FIREBASE_API_KEY="din-api-nyckel-har"
VITE_FIREBASE_AUTH_DOMAIN="ditt-projekt.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="ditt-projekt"
VITE_FIREBASE_STORAGE_BUCKET="ditt-projekt.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="din-sender-id"
VITE_FIREBASE_APP_ID="din-app-id"

# Google Cloud Vision OCR (Frivillig men rekommenderad för extrem precision)
# Om denna är tom faller appen tillbaka på Tesseract (Offline OCR).
# Skapa en API-nyckel i Google Cloud Console med Cloud Vision API aktiverat.
VITE_GOOGLE_VISION_API_KEY=""
